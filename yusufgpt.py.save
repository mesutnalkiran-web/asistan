# ---------------- METİN TEMİZLE ----------------

def temizle(text):

    text=re.sub(r"\[\d+\]","",text)

    return text


# ---------------- DJ YÜZÜ ----------------

class YusufDJFace:

    def __init__(self):

        self.root=tk.Tk()

        self.root.attributes("-fullscreen",True)

        self.root.configure(bg="black")

        self.canvas=tk.Canvas(
            self.root,
            width=self.root.winfo_screenwidth(),
            height=self.root.winfo_screenheight(),
            bg="black",
            highlightthickness=0
        )

        self.canvas.pack()

        self.sw=self.root.winfo_screenwidth()
        self.sh=self.root.winfo_screenheight()

        self.bars=[]
        self.is_speaking=False

        self.create_bars()
        self.animate()

    def create_bars(self):

        cx=self.sw//2
        cy=self.sh//2+300

        for i in range(30):

            x=cx-300+(i*20)

            bar=self.canvas.create_rectangle(
                x,cy,
                x+15,cy-10,
                fill="#00CCFF",
                outline=""
            )

            self.bars.append(bar)

    def animate(self):

        cy=self.sh//2+300

        for bar in self.bars:

            h=random.randint(40,200) if self.is_speaking else random.randint(5,20)

            coords=self.canvas.coords(bar)

            self.canvas.coords(bar,coords[0],cy-h,coords[2],cy)

        self.root.after(80,self.animate)

    def set_speaking(self,val):

        self.is_speaking=val


# ---------------- SES ----------------

async def speak(text):

    global face_app

    text=temizle(text)

    print("Yusuf:",text)

    file="voice.mp3"

    communicate=edge_tts.Communicate(text,"tr-TR-AhmetNeural")

    await communicate.save(file)

    if face_app:
        face_app.set_speaking(True)

    subprocess.run(["mpg123","-q",file])

    if face_app:
        face_app.set_speaking(False)

    os.remove(file)


# ---------------- DİNLE ----------------

def listen(duration=4):

    r=sr.Recognizer()

    try:

        os.system(f"rec -c 1 -r 16000 input.wav trim 0 {duration} > /dev/null 2>&1")

        with sr.AudioFile("input.wav") as source:

            audio=r.record(source)

        text=r.recognize_google(audio,language="tr-TR")

        return text.lower()

    except:
        return ""


# ---------------- MAIL ----------------

def send_mail(subject,text,image=None):

    msg=EmailMessage()

    msg["Subject"]=subject
    msg["From"]=GMAIL_USER
    msg["To"]=GMAIL_USER

    msg.set_content(text)

    if image:

        with open(image,"rb") as f:

            msg.add_attachment(
                f.read(),
                maintype="image",
                subtype="jpeg",
                filename="kamera.jpg"
            )

    with smtplib.SMTP_SSL("smtp.gmail.com",465) as s:

        s.login(GMAIL_USER,GMAIL_PASS)

        s.send_message(msg)


# ---------------- KAMERA ----------------

def kamera_cek():

    cap=cv2.VideoCapture(0)

    if not cap.isOpened():

        return None

    ret,frame=cap.read()

    if ret:

        file="snap.jpg"

        cv2.imwrite(file,frame)

        cap.release()

        return file

    cap.release()

    return None


# ---------------- KOMUT ONAY ----------------

async def komut_al():

    while True:

        text=listen(5)

        if WAKE_WORD in text:

            cmd=text.replace(WAKE_WORD,"").strip()

            if cmd=="":

                await speak("Efendim?")

                cmd=listen(4)

            if cmd=="":

                continue

            await speak(f"{cmd} dediniz doğru mu")

            cevap=listen(3)

            if "evet" in cevap or "doğru" in cevap:

                return cmd

            if "hayır" in cevap:

                await speak("Tekrar söylermisiniz")

                continue

            else:

                await speak("Anlayamadım tekrar söylermisiniz")


# ---------------- KOMUT İŞLE ----------------

async def komut_isle(cmd):

    global alarm_vakti

    if "şarj" in cmd:

        b=psutil.sensors_battery()

        await speak(f"Şarjım yüzde {b.percent}")

        return


    if "alarm" in cmd:

        saat=[s for s in cmd.split() if ":" in s]

        if saat:

            alarm_vakti=saat[0]

            await speak(f"Alarm {alarm_vakti} kuruldu")

        return


    if "çal" in cmd or "aç" in cmd:

        song=cmd.replace("çal","").replace("aç","")

        subprocess.Popen([
            "mpv",
            "--no-video",
            f"ytdl://ytsearch:{song}"
        ])

        await speak("Açıyorum")

        return


    if "kamera" in cmd or "gör" in cmd:

        await speak("Kameraya bakıyorum")

        img=kamera_cek()

        if img is None:

            await speak("Kamerayı açamadım")

            return

        with open(img,"rb") as f:

            b64=base64.b64encode(f.read()).decode()

        try:

            resp=client.chat.completions.create(

                model="sonar",

                messages=[

                {
                "role":"user",
                "content":[
                    {"type":"text","text":"Bu fotoğrafta ne var kısaca söyle"},
                    {"type":"image_url","image_url":{"url":f"data:image/jpeg;base64,{b64}"}}
                ]
                }]

            )

            cevap=resp.choices[0].message.content

            await speak(cevap)

        except:

            await speak("Analiz yapılamadı")

        return


    if "mail" in cmd:

        img=kamera_cek()

        if img:

            send_mail("Yusuf Kamera","Kamera görüntüsü",img)

            await speak("Fotoğrafı mail attım")

        else:

            await speak("Kamerayı açamadım")

        return


    try:

        resp=client.chat.completions.create(

            model="sonar",

            messages=[
                {"role":"system","content":"Kısa cevap ver ve efendim diye hitap et"},
                {"role":"user","content":cmd}
            ]
        )

        cevap=resp.choices[0].message.content

        await speak(cevap)

    except:

        await speak("İnternet sorunu var")


# ---------------- ALARM ----------------

def alarm_kontrol():

    global alarm_vakti

    while True:

        if alarm_vakti:

            simdi=datetime.now().strftime("%H:%M")

            if simdi>=alarm_vakti:

                subprocess.Popen([
                    "mpv",
                    "--no-video",
                    "ytdl://ytsearch:alarm müziği"
                ])

                asyncio.run(speak("Efendim alarm vakti"))

                alarm_vakti=None

        time.sleep(20)


# ---------------- ANA PROGRAM ----------------

async def yusuf():

    await speak("Sistem hazır efendim")

    while True:

        cmd=await komut_al()

        await komut_isle(cmd)



if __name__=="__main__":

    face_app=YusufDJFace()

    threading.Thread(target=alarm_kontrol,daemon=True).start()

    threading.Thread(target=lambda: asyncio.run(yusuf()),daemon=True).start()

    face_app.root.mainloop()
