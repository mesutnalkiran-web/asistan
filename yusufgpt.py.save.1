# ---------------- SES ----------------

async def speak(text):

    print("Yusuf:",text)

    file="voice.mp3"

    communicate=edge_tts.Communicate(text,"tr-TR-AhmetNeural")
    await communicate.save(file)

    subprocess.run(["mpg123","-q",file])

# ---------------- DINLE ----------------

def listen():

    r=sr.Recognizer()

    with sr.Microphone() as source:

        audio=r.listen(source)

    try:
        text=r.recognize_google(audio,language="tr-TR")
        print("Sen:",text)
        return text.lower()
    except:
        return ""

# ---------------- FOTO CEK ----------------

def foto_cek():

    path="snap.jpg"

    os.system(f"fswebcam -r 1280x720 --no-banner {path}")

    time.sleep(1)

    return path

# ---------------- YUZ VERITABANI YUKLE ----------------

def yuzleri_yukle():

    encodings=[]
    names=[]

    for file in os.listdir(yuz_klasor):

        if file.endswith(".jpg"):

            img=face_recognition.load_image_file(os.path.join(yuz_klasor,file))

            enc=face_recognition.face_encodings(img)

            if enc:
                encodings.append(enc[0])
                names.append(file.replace(".jpg",""))

    return encodings,names

# ---------------- YUZ TANIMA ----------------

def yuz_tani():

    encodings,names=yuzleri_yukle()

    foto=foto_cek()

    img=face_recognition.load_image_file(foto)

    faces=face_recognition.face_encodings(img)

    if not faces:
        return None

    face=faces[0]

    matches=face_recognition.compare_faces(encodings,face)

    if True in matches:

        index=matches.index(True)

        return names[index]

    return None

# ---------------- YUZ KAYDET ----------------

def yuz_kaydet(isim):

    path=os.path.join(yuz_klasor,f"{isim}.jpg")

    os.system(f"fswebcam -r 1280x720 --no-banner {path}")

# ---------------- TANISMA ----------------

async def tanisma():

    isim=yuz_tani()

    if isim:

        await speak(f"Merhaba {isim}. Seni tanıdım. Nasıl yardımcı olabilirim")

        return isim

    else:

        await speak("Sizi tanımıyorum. Tanışalım mı? Ben Yusuf. Siz kimsiniz")

        cevap=listen()

        if cevap:

            isim=cevap.split()[0]

            await speak(f"Memnun oldum {isim}")

            yuz_kaydet(isim)

            await speak("Artık sizi tanıyorum")

            return isim

    return None

# ---------------- GELEN KISI TAKIP ----------------

takip_kisi=None

async def kisi_kontrol():

    global takip_kisi

    while True:

        if takip_kisi:

            isim=yuz_tani()

            if isim==takip_kisi:

                await speak(f"Efendim {takip_kisi} geldi")

                takip_kisi=None

        time.sleep(20)

# ---------------- ANA MANTIK ----------------

async def yusuf_logic():

    global takip_kisi

    await speak("Sistem aktif. Dinliyorum")

    while True:

        query=listen()

        if not query:
            continue

        # ---- TANISMA TETIKLE ----

        if any(k in query for k in ["merhaba","nasılsın","beni tanıdın mı"]):

            await tanisma()

            continue

        # ---- KISI TAKIP ----

        if "gelince haber ver" in query:

            isim=query.split()[0]

            takip_kisi=isim

            await speak(f"Tamam. {isim} gelince haber vereceğim")

            continue

        # ---- SARJ ----

        if "şarj" in query:

            bat=psutil.sensors_battery()

            await speak(f"Şarjım yüzde {bat.percent}")

            continue

        # ---- MUZIK ----

        if "çal" in query or "aç" in query:

            muzik=query.replace("çal","").replace("aç","")

            os.system(f'mpv --no-video "ytdl://ytsearch:{muzik}" &')

            await speak("Açıyorum")

            continue

        # ---- DUR ----

        if any(x in query for x in ["sus","dur","kapat"]):

            os.system("pkill -9 mpv")

            await speak("Tamam sustum")

            continue

        await speak("Anlamadım efendim")

# ---------------- DJ ANIMASYON ----------------

class YusufFace:

    def __init__(self):

        self.root=tk.Tk()

        self.root.attributes("-fullscreen",True)

        self.canvas=tk.Canvas(self.root,bg="black")

        self.canvas.pack(fill="both",expand=True)

        self.animate()

    def animate(self):

        self.canvas.delete("all")

        w=self.root.winfo_screenwidth()
        h=self.root.winfo_screenheight()

        for i in range(30):

            x=random.randint(0,w)

            y=random.randint(0,h)

            size=random.randint(10,50)

            self.canvas.create_oval(x,y,x+size,y+size,fill="cyan")

        self.root.after(200,self.animate)

# ---------------- MAIN ----------------

async def main():

    threading.Thread(target=lambda:asyncio.run(kisi_kontrol()),daemon=True).start()

    await yusuf_logic()

face=YusufFace()

threading.Thread(target=lambda:asyncio.run(main()),daemon=True).start()

face.root.mainloop()
